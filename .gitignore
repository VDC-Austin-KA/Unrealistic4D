# ---- Cesium for Unreal (third-party binary plugin, ~hundreds of MB) ----
# Install from https://github.com/CesiumGS/cesium-unreal/releases (UE 5.7 build,
# CesiumForUnreal-57-*.zip) into Earth4DTemplate/Plugins/CesiumForUnreal/ after
# cloning. Build with EARTH4D_FORCE_CESIUM=1 to enable the Cesium backend.
Earth4DTemplate/Plugins/CesiumForUnreal/

# ---- Marketplace asset pack ----
# Construction_VOL1 is an Epic Marketplace pack (~586 MB, contains a >100 MB file).
# Not redistributed here; install it from the Epic Marketplace into
# Earth4DTemplate/Content/Construction_VOL1/ after cloning.
Earth4DTemplate/Content/Construction_VOL1/

# ---- Secrets (never commit) ----
# Per-user Claude API key + tiles keys live here (written by UEarth4DSettings).
Earth4DTemplate/Config/DefaultEarth4D.ini
**/Config/DefaultEarth4D.ini

# ---- OS / editor cruft ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Cesium request cache (large SQLite files) ----
Earth4DTemplate/cesium-request-cache.sqlite*
*.sqlite-shm
*.sqlite-wal

# ---- Claude Code session exports ----
*.txmmm

# ---- Plugin packaging output (UE "Package Plugin" / Fab submission) ----
# These HostProject wrappers embed a *copy* of the plugin; if left in the tree
# they give UBT duplicate "Earth4D" plugins and break the editor build
# ("Earth4D could not be compiled"). Regenerable — never commit.
Earth4D/Source/Earth4D/
**/HostProject/
**/HostProject */

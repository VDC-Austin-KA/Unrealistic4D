# Copy to .env (gitignored) or export in the environment. Never commit real values.

# --- Microsoft Entra ID (required unless EARTH4D_MCP_DISABLE_AUTH=1) ---
# Directory (tenant) ID of your Entra tenant.
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# Expected token audience: the server app registration's Application ID URI
# (api://<client-id>) or bare client id. Comma-separate to accept several.
ENTRA_AUDIENCE=api://00000000-0000-0000-0000-000000000000
# Optional: restrict callers to specific client app ids (azp/appid claim).
# Leave empty to accept any app that can obtain a valid token for the audience.
ENTRA_ALLOWED_APP_IDS=

# --- Server ---
PORT=3020
# Public HTTPS URL Copilot Studio reaches this server at (tunnel or host URL).
PUBLIC_BASE_URL=https://your-tunnel.example.com
# Directory the file/command tools are confined to. Defaults to the repo root
# (two levels above this folder).
WORKSPACE_ROOT=
# Max ms a run_command invocation may take (UE builds need generous values).
COMMAND_TIMEOUT_MS=600000
# Max bytes of tool output returned per call.
MAX_OUTPUT_BYTES=256000

# Dev only: skip token validation entirely. NEVER set this on an exposed host.
# EARTH4D_MCP_DISABLE_AUTH=1
